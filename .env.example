# 로컬 실행 전 이 파일을 .env로 복사하고 값은 자신의 환경에 맞게 변경하세요.
# 이 값은 예시일 뿐 실제 운영 secret이 아니며, 복사한 .env는 커밋하지 않습니다.
JWT_SECRET=local-dev-only-change-this-secret-at-least-32-bytes
JWT_EXPIRATION_MS=3600000
DB_URL=jdbc:mysql://localhost:3307/aandi_lab?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=root
